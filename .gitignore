# Saynaa ignore list

# folder
.vs/
.vscode/
.cache/
obj/
build/
tmp/

# saynaa packages
saynaa-packages/
references/

### C ###
# Prerequisites
*.d

# Object files & bytecode
*.o
*.ko
*.obj
*.elf
*.sbc

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
saynaa

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

### Vim ###
# Swap
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Session
Session.vim
Sessionx.vim

# Temporary
.netrwhist
/compile_commands.json
*~
/*.sw?
# Auto-generated tag files
tags
# Persistent undo
[._]*.un~