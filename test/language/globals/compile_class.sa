import io
import path
import compile

code = io.readfile("test/language/globals/compile_class_input.sa")

c = compile.Compile(code)
c.run()

out2 = c.save("test/language/globals/compile_class_custom.sbc")
assert(path.exists("test/language/globals/compile_class_custom.sbc"))

print("Compile class tests passed")
