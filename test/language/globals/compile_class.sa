import path
import compile

c = compile.Compile("test/language/globals/compile_class_input.sa")

c.run()

out1 = c.save()
assert(out1 == "test/language/globals/compile_class_input.sbc")
assert(path.exists(out1))

out2 = c.save("test/language/globals/compile_class_custom.sbc")
assert(path.exists(out2))

print("Compile class tests passed")
