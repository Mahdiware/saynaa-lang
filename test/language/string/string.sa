# expect: string methods ok

assert("  HeLLo \n".strip() == "HeLLo")
assert("HeLLo".lower() == "hello")
assert("HeLLo".upper() == "HELLO")
assert("hello".find("l") == 2)
assert("hello".find("l", 3) == 3)
assert("hello".find("z") == -1)
assert("hello".rfind("l") == 3)
assert("hello".rfind("l", 2) == 3)
assert("hello".rfind("z") == -1)
assert("hello".replace("l", "L") == "heLLo")
assert("hello".replace("l", "L", 1) == "heLlo")
assert("a,b,c".split(",").join("|") == "a|b|c")
assert("abc".split().join("") == "abc")
assert("hello".startswith("he") == true)
assert("hello".startswith(["x", "he"]) == true)
assert("hello".endswith("lo") == true)
assert("hello".endswith(["x", "lo"]) == true)
assert("hello".sub(1, 4) == "ell")
assert("hello".sub(-2) == "lo")
assert("world".reverse() == "dlrow")
assert("ha".rep(3) == "hahaha")
assert("ha".rep(0) == "")
assert("abc".byte(1) == 98)
assert("abc".byte(-1) == 99)
assert("name=%s age=%d".format("bob", 5) == "name=bob age=5")
assert("hello".match("ll") == "ll")
assert("hello".match("zz") == null)
assert("a-b-a".gsub("a", "x") == "x-b-x")
assert("a-b-a".gsub("a", "x", 1) == "x-b-a")
assert("a-b-a".gmatch("a").join(",") == "a,a")

print("string methods ok")