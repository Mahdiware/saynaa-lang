import package
# expect: Custom searcher import tests passed

# Predeclare to make name visible to compiler.
custom_import = "placeholder"

function _import(name)
    if name == "custom_import" then
        define(name, null)
        return true
    end

    if name == "bad_import_null" then
        return null
    end

    return null
end

package.searchers.append(_import)

ok1 = pcall(package.load, "custom_import")
assert(ok1[0] == true)
assert(custom_import == null)

ok4 = pcall(package.load, "bad_import_null")
assert(ok4[0] == false)

print("Custom searcher import tests passed")
