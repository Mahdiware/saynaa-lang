
# Validating map keys other than strings
m1 = {0: 10, true: false, null: function return null end }
assert(m1[0] == 10)
assert(m1[true] == false)
assert(m1[null] is Closure)
assert(m1[null].name == "@anonymous")

# Validating unquoted string keys in map literals
m1 = {name: "saynaa", version: 1.0}
assert(m1["name"] == "saynaa")
assert(m1["version"] == 1.0)
assert(m1.name == "saynaa")
assert(m1.version == 1.0)

# Validating map attribute access (get)
m2 = {"foo": "bar", "baz": 42}
assert(m2.foo == "bar")
assert(m2.baz == 42)

# Validating map attribute access (set)
m2.foo = "new_bar"
assert(m2.foo == "new_bar")
assert(m2["foo"] == "new_bar")

# Validating map attribute access (new entry)
m2.qux = true
assert(m2.qux == true)
assert(m2["qux"] == true)

# Validating variable key still works with parens
key_var = "dynamic_key"
m3 = {(key_var): "value"}
assert(m3["dynamic_key"] == "value")
assert(m3.dynamic_key == "value")

# Validating special properties priority
m4 = {length: 100}
assert(m4.length == 1)      # .length refers to map size
assert(m4["length"] == 100) # ["length"] refers to the key

# Validating map iteration with new syntax
m5 = {a: 1, b: 2}
count = 0
for k in m5 do
  if k == "a" then assert(m5.a == 1) end
  if k == "b" then assert(m5.b == 2) end
  count += 1
end
assert(count == 2)

# Validating map insertion order
m6 = {a: 1, 1: "one", b: 2, c: 3}
keys = []
for k in m6 do
  keys.append(k)
end
assert(keys == ["a", 1, "b", "c"])
assert(m6.keys == ["a", 1, "b", "c"])
assert(m6.values == [1, "one", 2, 3])

# Validating value-only map literal
m7 = {10, 20, 30}
assert(m7.keys == [0, 1, 2])
assert(m7.values == [10, 20, 30])
assert(m7[0] == 10)

# Validating mixed value-only and explicit keys
m8 = {10, 20, 2: 30, 40}
assert(m8.keys == [0, 1, 2, 3])
assert(m8.values == [10, 20, 30, 40])
