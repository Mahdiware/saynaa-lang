## Regression: class-object method binding must not be reused across different classes.

class A
  function f()
    return "A"
  end
end

class B
  function f()
    return "B"
  end
end

expected = ["A", "B", "A", "B", "A", "B", "A", "B", "A", "B"]
idx = 0

for c in [A, B, A, B, A, B, A, B, A, B]
  m = c.f
  assert(m.instance == c)
  assert(m() == expected[idx])
  idx += 1
end
