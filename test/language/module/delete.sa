import package
# expect: Package delete tests passed

x = 42
assert(x == 42)

delete("x")

fn = function return x end
ok = pcall(fn)
assert(ok[0] == false)

m = package.load("package")
m.define("y", 10)
assert(m.globals()["y"] == 10)

m.delete("y")
assert(m.globals().has("y") == false)

print("Package delete tests passed")
