# case_id="compile.frontend"
# phase="compile"
# description="Compile source to bytecode"
# mode="compile-only"

class Vec2
  function _init(x, y)
    this.x = x
    this.y = y
  end
end

class Vec3
  function _init(x, y, z)
    this.x = x
    this.y = y
    this.z = z
  end
end

class Matrix2
  function _init(a, b, c, d)
    this.a = a
    this.b = b
    this.c = c
    this.d = d
  end

  function mul(v)
    return Vec2(this.a * v.x + this.b * v.y,
                this.c * v.x + this.d * v.y)
  end
end

function dot2(a, b)
  return a.x * b.x + a.y * b.y
end

function dot3(a, b)
  return a.x * b.x + a.y * b.y + a.z * b.z
end

function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

function poly(x)
  return (((x * 3 + 7) * x - 11) * x + 23)
end

function reduce_sum(items)
  s = 0
  for i in items
    s += i
  end
  return s
end

function make_points(n)
  pts = []
  for i in 0..n
    pts.append(Vec2(i, i * 2))
  end
  return pts
end

function main()
  points = make_points(32)
  m = Matrix2(1, 2, 3, 4)

  acc = 0
  for p in points
    q = m.mul(p)
    acc += dot2(q, Vec2(2, 1))
  end

  v3 = Vec3(1, 2, 3)
  acc += dot3(v3, Vec3(3, 2, 1))
  acc += poly(clamp(14, 0, 10))
  acc += reduce_sum([1, 2, 3, 4, 5])

  assert(acc == 14054, "value: $acc")
end

import time

t0 = time.clock()
for i in 1..200000
  main()
end
t1 = time.clock()
print("Execution time: ", t1 - t0, " seconds")
