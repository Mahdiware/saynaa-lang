# case_id="runtime.collections"
# phase="runtime"
# description="List and map mutation/access"
# mode="run-source"
# ops=120000

items = []
index = {}

for i in 0..60000
  items.append(i)
  index[i] = i + 1
end

acc = 0
for i in 0..60000
  acc += index[i]
end

assert(items.length == 60000)
assert(acc > 0)
